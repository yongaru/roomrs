{
  "name": "sqlcipher",
  "version": "4.6.1",
  "port-version": 4,
  "description": "SQLCipher with preupdate hook support for roomrs live queries.",
  "homepage": "https://www.zetetic.net/sqlcipher",
  "license": "BSD-3-Clause",
  "supports": "windows & !uwp",
  "dependencies": [
    "openssl",
    "tcl",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "fts5": {
      "description": "enable FTS5 functionality for sqlite3"
    },
    "geopoly": {
      "description": "enable geopoly functionality for sqlite3"
    },
    "json1": {
      "description": "enable JSON functionality for sqlite3"
    },
    "tool": {
      "description": "sqlite3 executable"
    }
  }
}
